<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TravelCamApp"
             xmlns:converters="clr-namespace:TravelCamApp.Converters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="TravelCamApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Capture Mode Converters -->
            <converters:CaptureModeToColorConverter x:Key="ModeToColorConverter" />
            <converters:CaptureModeToTextColorConverter x:Key="ModeToTextColorConverter" />
            <converters:CaptureModeToFontAttributesConverter x:Key="ModeToFontConverter" />
            <converters:CaptureModeToVisibilityConverter x:Key="ModeToVisibilityConverter" />

            <!-- Camera UI Converters -->
            <converters:FlashIconColorConverter x:Key="FlashIconColorConverter" />
            <converters:ZoomPresetBackgroundConverter x:Key="ZoomBgConverter" />
            <converters:ZoomPresetTextColorConverter x:Key="ZoomTextConverter" />

            <!-- CommunityToolkit InvertedBool -->
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <toolkit:IsStringNotNullOrEmptyConverter x:Key="IsNotNullOrEmptyConverter" />

            <!-- Shared overlay settings icon style — visual properties only.
                 Path.Data must be set inline via {x:Static helpers:AppIcons.OverlaySettings}
                 because Style.Setter for Geometry does not reliably invoke TypeConverter. -->
            <Style x:Key="OverlaySettingsIconPath" TargetType="Path">
                <Setter Property="Fill" Value="White" />
                <Setter Property="Aspect" Value="Uniform" />
                <Setter Property="WidthRequest" Value="22" />
                <Setter Property="HeightRequest" Value="22" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
