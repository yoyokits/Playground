<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:TravelCamApp.ViewModels"
             xmlns:views="clr-namespace:TravelCamApp.Views"

             xmlns:converters="clr-namespace:TravelCamApp.Converters"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             xmlns:selectors="clr-namespace:TravelCamApp.Selectors"
             xmlns:helpers="clr-namespace:TravelCamApp.Helpers"
             xmlns:models="clr-namespace:TravelCamApp.Models"
             x:Class="TravelCamApp.Views.ImageViewerView"
             x:DataType="vm:MainPageViewModel">

    <ContentView.Resources>
        <converters:FilePathToImageSourceConverter x:Key="FilePathToImageSourceConverter" />
        <converters:ThumbnailConverter x:Key="ThumbnailConverter" />
        <converters:ExtensionEqualsConverter x:Key="ExtensionEqualsConverter" />
        <!-- Info button active state: blue fill when panel is open, transparent otherwise -->
        <converters:BoolToColorConverter x:Key="BoolToInfoBgConverter"
                                         TrueColor="#0A84FF"
                                         FalseColor="Transparent" />
        <!-- Info button border: hidden when active (fill shows), white ring when inactive -->
        <converters:BoolToColorConverter x:Key="BoolToInfoStrokeConverter"
                                         TrueColor="Transparent"
                                         FalseColor="White" />

        <!-- Image template for photos -->
        <DataTemplate x:Key="ImageTemplate" x:DataType="sys:String">
            <Image Source="{Binding ., Converter={StaticResource FilePathToImageSourceConverter}}"
                   Aspect="AspectFit"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill" />
        </DataTemplate>

        <!-- Video template: poster image + tap-to-play overlay only.
             NO MediaElement here — a single shared MediaElement lives outside the
             CarouselView so only one ExoPlayer instance ever exists. Having a
             MediaElement per carousel item exhausts ExoPlayer on rapid swipes. -->
        <DataTemplate x:Key="VideoTemplate" x:DataType="sys:String">
            <Grid BackgroundColor="Black">
                <!-- Poster thumbnail -->
                <Image Source="{Binding ., Converter={StaticResource ThumbnailConverter}}"
                       Aspect="AspectFit"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill" />
                <!-- Tap-to-play overlay -->
                <Border BackgroundColor="#88000000" Stroke="Transparent"
                        StrokeShape="Ellipse"
                        WidthRequest="72" HeightRequest="72"
                        HorizontalOptions="Center" VerticalOptions="Center">
                    <Path Data="M10,8 L26,17 L10,26 Z"
                          Fill="White" Aspect="Uniform"
                          WidthRequest="28" HeightRequest="28"
                          HorizontalOptions="Center" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVideoPlayTapped" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Selector that chooses template based on file extension -->
        <selectors:MediaTemplateSelector x:Key="MediaTemplateSelector"
                                         ImageTemplate="{StaticResource ImageTemplate}"
                                         VideoTemplate="{StaticResource VideoTemplate}" />
    </ContentView.Resources>


    <ContentView.Content>
        <Grid RowDefinitions="Auto,*,Auto,Auto" BackgroundColor="Black">

            <!-- ── Row 0: Top bar — Close | position text ── -->
            <Grid Grid.Row="0" Padding="12,8,12,8"
                  ColumnDefinitions="Auto,*"
                  BackgroundColor="Black">

                <!-- Close button -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="#AA000000" Stroke="Transparent"
                        WidthRequest="44" HeightRequest="44">
                    <Label Text="✕" FontSize="16" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseImageViewerCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Position indicator (e.g. "3 / 15") -->
                <Label Grid.Column="1"
                       Text="{Binding ImagePositionText}"
                       FontSize="14" TextColor="#CCCCCC"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

            <!-- ── Row 1: CarouselView + shared video player overlay ── -->
            <Grid x:Name="ImageAreaGrid" Grid.Row="1" BackgroundColor="Black"
                  SizeChanged="OnImageAreaSizeChanged">

                <CarouselView x:Name="MainCarousel"
                              ItemsSource="{Binding GalleryImagePaths}"
                              Position="{Binding CurrentImageIndex, Mode=OneWay}"
                              PositionChanged="OnCarouselPositionChanged"
                              Loop="False"
                              HorizontalScrollBarVisibility="Never"
                              VerticalScrollBarVisibility="Never"
                              BackgroundColor="Black">
                    <CarouselView.ItemTemplate>
                        <StaticResource Key="MediaTemplateSelector" />
                    </CarouselView.ItemTemplate>
                </CarouselView>

                <!-- Single shared MediaElement: only ONE ExoPlayer instance ever exists.
                     Hidden by default; shown when user taps play on a video item.
                     Stopped and hidden again when swiping or closing gallery. -->
                <toolkit:MediaElement x:Name="SharedVideoPlayer"
                                      IsVisible="False"
                                      Aspect="AspectFit"
                                      HorizontalOptions="Fill"
                                      VerticalOptions="Fill"
                                      BackgroundColor="Black"
                                      ShouldShowPlaybackControls="True"
                                      ShouldAutoPlay="False" />

            </Grid>

            <!-- ── Row 2: Thumbnail strip ── -->
            <CollectionView Grid.Row="2"
                            x:Name="ThumbnailStrip"
                            ItemsSource="{Binding GalleryImagePaths}"
                            SelectedItem="{Binding CurrentImageItem, Mode=TwoWay}"
                            HeightRequest="72"
                            BackgroundColor="#1A1A1A"
                            SelectionMode="Single"
                            SelectionChanged="OnThumbnailSelected">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="0" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="sys:String">
                        <!-- Thumbnail displays the smallest preview -->
                        <Border StrokeShape="RoundRectangle 4"
                                Stroke="Transparent"
                                Padding="2" Margin="3,6"
                                WidthRequest="60" HeightRequest="60"
                                BackgroundColor="#333333">
                            <Grid WidthRequest="56" HeightRequest="56">
                                <Image Source="{Binding ., Converter={StaticResource ThumbnailConverter}}"
                                       Aspect="AspectFill"
                                       WidthRequest="56" HeightRequest="56" />
                                <!-- Circular play icon overlay for videos -->
                                <Border BackgroundColor="#99000000" Stroke="Transparent"
                                        StrokeShape="Ellipse"
                                        WidthRequest="24" HeightRequest="24"
                                        HorizontalOptions="Center" VerticalOptions="Center"
                                        IsVisible="{Binding ., Converter={StaticResource ExtensionEqualsConverter}, ConverterParameter=.mp4}">
                                    <Path Data="M6,4 L18,12 L6,20 Z"
                                          Fill="White" Aspect="Uniform"
                                          WidthRequest="10" HeightRequest="10"
                                          HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- ── Row 3: Bottom action bar — Settings | Info | Share | Delete ── -->
            <Grid Grid.Row="3" Padding="24,8,24,16"
                  ColumnDefinitions="*,*,*,*"
                  BackgroundColor="Black">

                <!-- Overlay settings button — active when settings panel is open -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="{Binding IsGallerySettingsVisible, Converter={StaticResource BoolToInfoBgConverter}}"
                        Stroke="{Binding IsGallerySettingsVisible, Converter={StaticResource BoolToInfoStrokeConverter}}"
                        StrokeThickness="1.5"
                        WidthRequest="48" HeightRequest="48"
                        HorizontalOptions="Center">
                    <Path Data="{x:Static helpers:AppIcons.OverlaySettings}"
                          Style="{StaticResource OverlaySettingsIconPath}" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Info button — Samsung-style circle "i" -->
                <Border Grid.Column="1"
                        StrokeShape="Ellipse"
                        BackgroundColor="{Binding IsMediaInfoVisible, Converter={StaticResource BoolToInfoBgConverter}}"
                        Stroke="{Binding IsMediaInfoVisible, Converter={StaticResource BoolToInfoStrokeConverter}}"
                        StrokeThickness="1.5"
                        WidthRequest="48" HeightRequest="48"
                        HorizontalOptions="Center">
                    <Label Text="i" FontSize="18" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleMediaInfoCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Share button -->
                <Border Grid.Column="2"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="#AA000000" Stroke="Transparent"
                        WidthRequest="48" HeightRequest="48"
                        HorizontalOptions="Center">
                    <Path Data="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"
                          Fill="White" Aspect="Uniform"
                          WidthRequest="20" HeightRequest="20"
                          HorizontalOptions="Center" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShareImageCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Delete button -->
                <Border Grid.Column="3"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="#AA000000" Stroke="Transparent"
                        WidthRequest="48" HeightRequest="48"
                        HorizontalOptions="Center">
                    <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                          Fill="White" Aspect="Uniform"
                          WidthRequest="24" HeightRequest="24"
                          HorizontalOptions="Center" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DeleteImageCommand}" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <!-- ── Data overlay pill (bottom-right of actual image) ── -->
            <!-- Binds to DataOverlayViewModel.VisibleOverlayItems (live sensor data) — same
                 source as the camera overlay, so both always show identical items and values.
                 Margin is set from code-behind (UpdateOverlayPositionAsync) to compensate
                 for AspectFit letterbox/pillarbox bars that vary per image. -->
            <Border x:Name="DataOverlayPill"
                    Grid.Row="1"
                    HorizontalOptions="End" VerticalOptions="End"
                    Margin="0,0,12,12"
                    BackgroundColor="#99000000"
                    StrokeShape="RoundRectangle 10"
                    Stroke="Transparent"
                    Padding="10,10"
                    IsVisible="{Binding CameraSettings.ShowDataOverlay}">
                <VerticalStackLayout Spacing="4"
                                     HorizontalOptions="Start"
                                     BindableLayout.ItemsSource="{Binding DataOverlayViewModel.VisibleOverlayItems}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:OverlayItem">
                            <VerticalStackLayout Spacing="0" HorizontalOptions="Start">
                                <Label Text="{Binding Name}"
                                       FontSize="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DataOverlayViewModel.LabelFontSize}"
                                       CharacterSpacing="0.6"
                                       TextColor="#9E9E9E"
                                       LineBreakMode="NoWrap"
                                       TextTransform="Uppercase" />
                                <Label Text="{Binding Value}"
                                       FontSize="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DataOverlayViewModel.ValueFontSize}"
                                       FontAttributes="Bold"
                                       TextColor="#FFFFFF"
                                       LineBreakMode="NoWrap" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Border>

            <!-- ── Media Info Overlay (spans all rows) ── -->
            <!-- Dimmed backdrop — tap to close -->
            <Grid Grid.Row="0" Grid.RowSpan="4"
                  BackgroundColor="#CC000000"
                  IsVisible="{Binding IsMediaInfoVisible}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnInfoBackdropTapped" />
                </Grid.GestureRecognizers>

                <Border Margin="24,40"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="#111111"
                        Stroke="Transparent"
                        VerticalOptions="Center"
                        HorizontalOptions="Fill">
                    <!-- Absorb taps on the card so they don't reach the backdrop -->
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnInfoCardTapped" />
                    </Border.GestureRecognizers>

                    <!-- Sticky header + scrollable body -->
                    <Grid RowDefinitions="Auto,Auto,*">

                        <!-- Sticky header — always visible above the scroll area -->
                        <Grid Grid.Row="0" Padding="20,20,16,16" ColumnDefinitions="*,Auto"
                              BackgroundColor="#111111">
                            <Label Grid.Column="0"
                                   Text="MEDIA INFO"
                                   FontSize="13" CharacterSpacing="1.2"
                                   FontAttributes="Bold" TextColor="#8E8E93"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 16"
                                    BackgroundColor="#2C2C2E" Stroke="Transparent"
                                    WidthRequest="32" HeightRequest="32">
                                <Label Text="✕" FontSize="13" TextColor="#ABABAB"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleMediaInfoCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                        <BoxView Grid.Row="1" HeightRequest="0.5" BackgroundColor="#2C2C2E" />

                    <ScrollView Grid.Row="2" MaximumHeightRequest="460" BackgroundColor="#111111">
                        <VerticalStackLayout Padding="0" Spacing="0">

                            <!-- FILE section — always shown -->
                            <VerticalStackLayout Padding="20,16,20,0" Spacing="0">
                                <Label Text="FILE"
                                       FontSize="11" CharacterSpacing="1.0"
                                       FontAttributes="Bold" TextColor="#8E8E93"
                                       Margin="0,0,0,10" />
                                <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                        BackgroundColor="#1C1C1E" Padding="16,4">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Name" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.FileName}"
                                                   FontSize="13" TextColor="#8E8E93"
                                                   LineBreakMode="TailTruncation"
                                                   MaximumWidthRequest="160" />
                                        </Grid>
                                        <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Size" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.FileSizeText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                        <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Date" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.CaptureDateText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <!-- CAMERA section -->
                            <VerticalStackLayout Padding="20,16,20,0" Spacing="0"
                                                 IsVisible="{Binding CurrentMediaInfo.HasCameraInfo}">
                                <Label Text="CAMERA"
                                       FontSize="11" CharacterSpacing="1.0"
                                       FontAttributes="Bold" TextColor="#8E8E93"
                                       Margin="0,0,0,10" />
                                <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                        BackgroundColor="#1C1C1E" Padding="16,4">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Device" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.DeviceDisplay}"
                                                   FontSize="13" TextColor="#8E8E93"
                                                   LineBreakMode="TailTruncation"
                                                   MaximumWidthRequest="160" />
                                        </Grid>
                                        <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Resolution" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.ResolutionText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                        <!-- Megapixels row — shown only when MP value is available -->
                                        <VerticalStackLayout IsVisible="{Binding CurrentMediaInfo.HasMegaPixelText}" Spacing="0">
                                            <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                            <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                                <Label Grid.Column="0" Text="Megapixels" FontSize="14" TextColor="#FFFFFF" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding CurrentMediaInfo.MegaPixelText}"
                                                       FontSize="13" TextColor="#8E8E93" />
                                            </Grid>
                                        </VerticalStackLayout>
                                        <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Aspect Ratio" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.AspectRatioText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                        <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Flash" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.FlashText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <!-- LOCATION section -->
                            <VerticalStackLayout Padding="20,16,20,0" Spacing="0"
                                                 IsVisible="{Binding CurrentMediaInfo.HasLocationInfo}">
                                <Label Text="LOCATION"
                                       FontSize="11" CharacterSpacing="1.0"
                                       FontAttributes="Bold" TextColor="#8E8E93"
                                       Margin="0,0,0,10" />
                                <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                        BackgroundColor="#1C1C1E" Padding="16,4">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="City" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.CityText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                        <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Country" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.CountryText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                        <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="GPS" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.GpsCoordsText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                        <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Altitude" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.AltitudeText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <!-- CONDITIONS section -->
                            <VerticalStackLayout Padding="20,16,20,24" Spacing="0"
                                                 IsVisible="{Binding CurrentMediaInfo.HasConditionsInfo}">
                                <Label Text="CONDITIONS"
                                       FontSize="11" CharacterSpacing="1.0"
                                       FontAttributes="Bold" TextColor="#8E8E93"
                                       Margin="0,0,0,10" />
                                <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                        BackgroundColor="#1C1C1E" Padding="16,4">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Temperature" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.TemperatureText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                        <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Heading" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.HeadingText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                        <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                            <Label Grid.Column="0" Text="Speed" FontSize="14" TextColor="#FFFFFF" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding CurrentMediaInfo.SpeedText}"
                                                   FontSize="13" TextColor="#8E8E93" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </ScrollView>

                    </Grid><!-- end sticky-header Grid -->
                </Border>
            </Grid>

            <!-- ── Data overlay settings panel (spans all rows) ── -->
            <!-- IsVisible is managed from code-behind (WireSensorSettings) to avoid
                 BindingContext conflict: this element's BindingContext is set to
                 OverlaySettingsViewModel at runtime, so XAML bindings to
                 MainPageViewModel properties won't resolve correctly. -->
            <views:OverlaySettingsView
                x:Name="DataOverlaySettingsPanel"
                Grid.Row="0" Grid.RowSpan="4"
                IsVisible="False"
                HorizontalOptions="Fill" VerticalOptions="Fill"
                InputTransparent="False" />

        </Grid>
    </ContentView.Content>

</ContentView>
