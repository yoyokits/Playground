<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:views="clr-namespace:TravelCamApp.Views"
             xmlns:vm="clr-namespace:TravelCamApp.ViewModels"
             xmlns:models="clr-namespace:TravelCamApp.Models"
             xmlns:helpers="clr-namespace:TravelCamApp.Helpers"
             x:Class="TravelCamApp.Views.MainPage"
             x:DataType="vm:MainPageViewModel"
             x:Name="ThisPage"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False">

    <!-- Root: two rows — camera preview (fills) + fixed black bottom panel -->
    <Grid RowDefinitions="*,Auto">

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 0 — Camera preview with all overlays stacked inside
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" BackgroundColor="Black">

            <!-- ── Camera feed ── -->
            <!-- Fill width; height naturally set to camera feed's aspect ratio (VerticalOptions="Start").
                 naturalW/naturalH in ApplyCameraLayout then equals cameraView.Width/Height directly. -->
            <toolkit:CameraView x:Name="CameraView"
                                HorizontalOptions="Fill"
                                VerticalOptions="Start"
                                SizeChanged="OnCameraViewSizeChanged" />

            <!-- ── Aspect ratio crop bars (sized and toggled from ApplyCameraLayout) ── -->
            <BoxView x:Name="CropTopBar"    BackgroundColor="Black" HorizontalOptions="Fill"  VerticalOptions="Start" IsVisible="False" />
            <BoxView x:Name="CropBottomBar" BackgroundColor="Black" HorizontalOptions="Fill"  VerticalOptions="Start" IsVisible="False" />
            <BoxView x:Name="CropLeftBar"   BackgroundColor="Black" HorizontalOptions="Start" VerticalOptions="Start" IsVisible="False" />
            <BoxView x:Name="CropRightBar"  BackgroundColor="Black" HorizontalOptions="End"   VerticalOptions="Start" IsVisible="False" />

<!-- ── CameraViewChildrenContainer: Container that aligns with visible camera feed ──
                 Positioned at top-center to align with camera preview (which now fills width and starts at top).
                 Container is centered horizontally and aligned to top vertically.
                 It contains the rule-of-thirds grid and sensor overlay as children. -->
            <Grid x:Name="CameraViewChildrenContainer"
                  HorizontalOptions="Start"
                  VerticalOptions="Start"
                  InputTransparent="False">

                <!-- ── Zoom pills strip — top center of visible camera feed ──
                     Only shown when device has more than one camera (ShowZoomPresets). -->
                <Border VerticalOptions="Start" HorizontalOptions="Center"
                        Margin="0,12,0,0"
                        StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        BackgroundColor="#66000000" Padding="6,4"
                        IsVisible="{Binding ShowZoomPresets}">
                    <HorizontalStackLayout Spacing="2"
                        BindableLayout.ItemsSource="{Binding ZoomPresets}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:ZoomPreset">
                                <Border StrokeShape="RoundRectangle 13" Stroke="Transparent"
                                        MinimumWidthRequest="36" HeightRequest="28"
                                        Padding="6,0"
                                        BackgroundColor="{Binding PillBackground}">
                                    <Label Text="{Binding Label}"
                                           FontSize="{Binding LabelSize}"
                                           FontAttributes="Bold"
                                           TextColor="{Binding LabelColor}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectCommand}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </Border>

                <!-- ── Rule-of-thirds grid lines (inside container)
                     Fills entire container (HorizontalOptions="Fill" VerticalOptions="Fill").
                     Now positioned relative to the visible camera feed, not full CameraView bounds. -->
                <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*,*"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      InputTransparent="True"
                      IsVisible="{Binding CameraSettings.ShowRuleOfThirds}">
                    <!-- Vertical line 1: spans all rows (1-3), use VerticalOptions="Fill" to stretch full height -->
                    <BoxView Grid.Column="1" Grid.RowSpan="3"
                             WidthRequest="0.5" HorizontalOptions="Start"
                             VerticalOptions="Fill"
                             Color="{Binding CameraSettings.GridLineColor}" />
                    <!-- Vertical line 2: spans all rows (1-3), use VerticalOptions="Fill" to stretch full height -->
                    <BoxView Grid.Column="2" Grid.RowSpan="3"
                             WidthRequest="0.5" HorizontalOptions="Start"
                             VerticalOptions="Fill"
                             Color="{Binding CameraSettings.GridLineColor}" />
                    <!-- Horizontal line 1: spans all columns, use HorizontalOptions="Fill" to stretch full width -->
                    <BoxView Grid.Row="1" Grid.ColumnSpan="3"
                             HeightRequest="0.5" VerticalOptions="Start"
                             HorizontalOptions="Fill"
                             Color="{Binding CameraSettings.GridLineColor}" />
                    <!-- Horizontal line 2: spans all columns, use HorizontalOptions="Fill" to stretch full width -->
                    <BoxView Grid.Row="2" Grid.ColumnSpan="3"
                             HeightRequest="0.5" VerticalOptions="Start"
                             HorizontalOptions="Fill"
                             Color="{Binding CameraSettings.GridLineColor}" />
                </Grid>

                <!-- ── Data overlay (inside container) ── -->
                <views:DataOverlayView
                    HorizontalOptions="End" VerticalOptions="End"
                    Margin="0,0,12,12"
                    IsVisible="{Binding CameraSettings.ShowDataOverlay}" />

                <!-- ── Right-side controls column: Camera Settings | Flash | Sensor ──
                     Stacked vertically at top-right of the visible camera feed area. -->
                <VerticalStackLayout HorizontalOptions="End" VerticalOptions="Start"
                                     Margin="0,12,12,0" Spacing="8"
                                     IsVisible="{Binding HasCameraPermission}">

                    <!-- Camera settings gear -->
                    <Border StrokeShape="RoundRectangle 22"
                            BackgroundColor="#55000000" Stroke="Transparent"
                            WidthRequest="44" HeightRequest="44">
                        <Path Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                              Fill="White" Aspect="Uniform"
                              WidthRequest="22" HeightRequest="22"
                              HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenCameraSettingsCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Flash toggle -->
                    <Grid WidthRequest="44" HeightRequest="44">
                        <Border StrokeShape="RoundRectangle 22"
                                BackgroundColor="#55000000" Stroke="Transparent"
                                WidthRequest="44" HeightRequest="44" />
                        <Path Data="M7,2V13H10V22L17,10H13L17,2H7Z M2,22Z M19,2Z"
                              Fill="#FFD60A" Aspect="Uniform"
                              WidthRequest="22" HeightRequest="22"
                              HorizontalOptions="Center" VerticalOptions="Center"
                              IsVisible="{Binding IsFlashOn}" />
                        <Path Data="M17,10H13L17,2H7V4.18L15.46,12.64M3.27,3L2,4.27L7,9.27V13H10V22L13.58,15.86L17.73,20L19,18.73L3.27,3Z"
                              Fill="White" Aspect="Uniform"
                              WidthRequest="22" HeightRequest="22"
                              HorizontalOptions="Center" VerticalOptions="Center"
                              IsVisible="{Binding IsFlashOn,
                                          Converter={StaticResource InvertedBoolConverter}}" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFlashCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- Sensor overlay settings -->
                    <Grid WidthRequest="44" HeightRequest="44">
                        <Border StrokeShape="RoundRectangle 22"
                                BackgroundColor="#55000000" Stroke="Transparent"
                                WidthRequest="44" HeightRequest="44" />
                        <Path Data="{x:Static helpers:AppIcons.OverlaySettings}"
                              Style="{StaticResource OverlaySettingsIconPath}" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                </VerticalStackLayout>

            </Grid>
            <!-- ═══ END CameraViewChildrenContainer ═══ -->

            <!-- ── Permission / loading overlay ── -->
            <AbsoluteLayout IsVisible="{Binding HasCameraPermission,
                                Converter={StaticResource InvertedBoolConverter}}">
                <VerticalStackLayout
                    AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                    AbsoluteLayout.LayoutFlags="PositionProportional"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Spacing="16">
                    <ActivityIndicator IsRunning="True" Color="White"
                                       WidthRequest="48" HeightRequest="48" />
                    <Label Text="{Binding PermissionStatus}"
                           FontSize="15" TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </AbsoluteLayout>

            <!-- ── Recording timer (top-center, only visible while recording) ── -->
            <HorizontalStackLayout VerticalOptions="Start"
                                   HorizontalOptions="Center"
                                   Margin="0,16,0,0"
                                   Spacing="6"
                                   IsVisible="{Binding IsRecording}">
                <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4"
                         BackgroundColor="#FF3B30" VerticalOptions="Center" />
                <Label Text="{Binding RecordingTimeText}"
                       FontSize="15" TextColor="#FF3B30" FontAttributes="Bold"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- ── Shutter flash feedback — white overlay, fades on photo capture ──
                 Always rendered (Opacity=0) so FadeTo starts instantly with no IsVisible delay. -->
            <BoxView x:Name="ShutterFlash"
                     BackgroundColor="White"
                     Opacity="0"
                     InputTransparent="True"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill" />

        </Grid>
        <!-- ═══ END ROW 0 ═══ -->


        <!-- ═══════════════════════════════════════════════════════════════
             ROW 1 — Bottom control panel (solid black)
        ═══════════════════════════════════════════════════════════════════ -->
        <VerticalStackLayout Grid.Row="1" BackgroundColor="Black"
                             Padding="0,16,0,8" Spacing="12">

            <!-- ── Main controls: thumbnail | PHOTO | shutter | VIDEO | flip ── -->
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto" Padding="16,0" ColumnSpacing="0">

                <!-- Gallery thumbnail — circular like Samsung reference -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 28"
                        Stroke="White" StrokeThickness="1.5"
                        WidthRequest="56" HeightRequest="56"
                        BackgroundColor="#1AFFFFFF"
                        HorizontalOptions="Center" VerticalOptions="Center">
                    <Image Source="{Binding LastCaptureImage}"
                           Aspect="AspectFill"
                           WidthRequest="53" HeightRequest="53" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenGalleryCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- PHOTO mode toggle — left of shutter -->
                <VerticalStackLayout Grid.Column="1" Spacing="4"
                                     HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="PHOTO" FontSize="12" CharacterSpacing="1.5"
                           FontAttributes="{Binding SelectedMode,
                               Converter={StaticResource ModeToFontConverter},
                               ConverterParameter=Photo}"
                           TextColor="{Binding SelectedMode,
                               Converter={StaticResource ModeToTextColorConverter},
                               ConverterParameter=Photo}"
                           HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetPhotoModeCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView WidthRequest="5" HeightRequest="5" CornerRadius="2.5"
                             BackgroundColor="White" HorizontalOptions="Center"
                             IsVisible="{Binding SelectedMode,
                                 Converter={StaticResource ModeToVisibilityConverter},
                                 ConverterParameter=Photo}" />
                </VerticalStackLayout>

                <!-- ── Shutter button (center) ── Samsung style: big ring + fill ── -->
                <Grid x:Name="ShutterButton"
                      Grid.Column="2"
                      WidthRequest="82" HeightRequest="82"
                      HorizontalOptions="Center" VerticalOptions="Center">

                    <!-- Outer ring -->
                    <Border StrokeShape="RoundRectangle 41"
                            Stroke="White" StrokeThickness="3"
                            BackgroundColor="Transparent"
                            WidthRequest="82" HeightRequest="82" />

                    <!-- Inner circle: white (Photo) or red (Video, not recording) -->
                    <Border StrokeShape="RoundRectangle 31"
                            Stroke="Transparent"
                            BackgroundColor="{Binding SelectedMode,
                                Converter={StaticResource ModeToColorConverter}}"
                            WidthRequest="66" HeightRequest="66"
                            HorizontalOptions="Center" VerticalOptions="Center"
                            IsVisible="{Binding IsRecording,
                                Converter={StaticResource InvertedBoolConverter}}" />

                    <!-- Stop square — shown while recording -->
                    <Border StrokeShape="RoundRectangle 7"
                            Stroke="Transparent"
                            BackgroundColor="#FF3B30"
                            WidthRequest="32" HeightRequest="32"
                            HorizontalOptions="Center" VerticalOptions="Center"
                            IsVisible="{Binding IsRecording}" />

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnShutterTapped" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- VIDEO mode toggle — right of shutter -->
                <VerticalStackLayout Grid.Column="3" Spacing="4"
                                     HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="VIDEO" FontSize="12" CharacterSpacing="1.5"
                           FontAttributes="{Binding SelectedMode,
                               Converter={StaticResource ModeToFontConverter},
                               ConverterParameter=Video}"
                           TextColor="{Binding SelectedMode,
                               Converter={StaticResource ModeToTextColorConverter},
                               ConverterParameter=Video}"
                           HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetVideoModeCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView WidthRequest="5" HeightRequest="5" CornerRadius="2.5"
                             BackgroundColor="White" HorizontalOptions="Center"
                             IsVisible="{Binding SelectedMode,
                                 Converter={StaticResource ModeToVisibilityConverter},
                                 ConverterParameter=Video}" />
                </VerticalStackLayout>

                <!-- Camera flip — circular Samsung-style -->
                <Grid Grid.Column="4"
                      WidthRequest="56" HeightRequest="56"
                      HorizontalOptions="Center" VerticalOptions="Center">
                    <Border StrokeShape="RoundRectangle 28"
                            BackgroundColor="#33FFFFFF" Stroke="Transparent"
                            WidthRequest="56" HeightRequest="56" />
                    <Path Data="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 16c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 9.74C4.46 10.97 4 12.43 4 14c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"
                          Fill="White" Aspect="Uniform"
                          WidthRequest="28" HeightRequest="28"
                          HorizontalOptions="Center" VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleCameraCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

            </Grid>

        </VerticalStackLayout>
        <!-- ═══ END ROW 1 ═══ -->


        <!-- ═══════════════════════════════════════════════════════════════
             OVERLAYS — full-screen, above both rows
        ═══════════════════════════════════════════════════════════════════ -->

        <!-- Data overlay settings panel -->
        <views:OverlaySettingsView
            x:Name="DataOverlaySettingsPanel"
            Grid.RowSpan="2"
            IsVisible="{Binding Source={x:Reference ThisPage},
                Path=BindingContext.IsSettingsVisible}"
            HorizontalOptions="Fill" VerticalOptions="Fill"
            InputTransparent="False" />

        <!-- Camera settings panel -->
        <views:CameraSettingsView
            x:Name="CameraSettingsOverlay"
            Grid.RowSpan="2"
            IsVisible="{Binding Source={x:Reference ThisPage},
                Path=BindingContext.IsCameraSettingsVisible}"
            HorizontalOptions="Fill" VerticalOptions="Fill"
            InputTransparent="False" />

        <!-- Image viewer overlay — full-screen, above all other overlays -->
        <views:ImageViewerView
            x:Name="GalleryView"
            Grid.RowSpan="2"
            IsVisible="{Binding IsImageViewerVisible}"
            HorizontalOptions="Fill" VerticalOptions="Fill"
            InputTransparent="False" />

    </Grid>
</ContentPage>
