<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:views="clr-namespace:TravelCamApp.Views"
             x:Class="TravelCamApp.Views.MainPage"
             x:Name="ThisPage"
             BackgroundColor="Black">

    <Grid RowDefinitions="*,Auto">

        <!-- Row 0: Camera Preview Area -->
        <Grid Grid.Row="0" BackgroundColor="Black">
            <!-- Camera View -->
            <toolkit:CameraView
                x:Name="CameraView"
                HorizontalOptions="Fill"
                VerticalOptions="Fill" />

            <!-- Loading / Permission Overlay -->
            <AbsoluteLayout x:Name="PermissionOverlay"
                            IsVisible="{Binding HasCameraPermission, Converter={StaticResource InvertedBoolConverter}}">
                <VerticalStackLayout AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                                     AbsoluteLayout.LayoutFlags="PositionProportional"
                                     HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                    <ActivityIndicator IsRunning="True" Color="White" WidthRequest="48" HeightRequest="48" />
                    <Label Text="{Binding PermissionStatus}"
                           FontSize="16" TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </AbsoluteLayout>

            <!-- Sensor Value Overlay (bottom-right) -->
            <views:SensorValueView
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,16,16"
                IsVisible="{Binding IsSensorOverlayVisible}" />

            <!-- Recording Indicator (top-center) -->
            <HorizontalStackLayout IsVisible="{Binding IsRecording}"
                                   Spacing="8"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Start"
                                   Margin="0,16,0,0">
                <BoxView Color="Red" WidthRequest="10" HeightRequest="10" CornerRadius="5"
                         VerticalOptions="Center" />
                <Label Text="{Binding RecordingTimeText}"
                       FontSize="16" TextColor="Red"
                       FontAttributes="Bold" />
            </HorizontalStackLayout>

            </Grid>

            <!-- Row 1: Control Panel -->
        <Grid Grid.Row="1"
              BackgroundColor="Black"
              Padding="16,12"
              RowDefinitions="Auto,Auto"
              RowSpacing="8">

            <!-- Main Controls Row -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,*" ColumnSpacing="16">
                <!-- Gallery Thumbnail (left) -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 28"
                        Stroke="White"
                        StrokeThickness="2"
                        WidthRequest="56" HeightRequest="56"
                        BackgroundColor="Transparent"
                        VerticalOptions="Center"
                        HorizontalOptions="Start">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenGalleryCommand}" />
                    </Border.GestureRecognizers>
                    <Image Source="{Binding LastCaptureImage}"
                           Aspect="AspectFill" />
                </Border>

                <!-- Shutter / Record Button (center) -->
                <Button Grid.Column="1"
                        Text="{Binding SelectedMode, Converter={StaticResource ModeToTextConverter}}"
                        FontSize="18"
                        FontAttributes="Bold"
                        WidthRequest="80" HeightRequest="80"
                        CornerRadius="40"
                        BackgroundColor="{Binding SelectedMode, Converter={StaticResource ModeToColorConverter}}"
                        TextColor="{Binding SelectedMode, Converter={StaticResource ModeToButtonTextColorConverter}}"
                        Command="{Binding CaptureCommand}" />

                <!-- Camera Flip (right) -->
                <Border Grid.Column="2"
                        StrokeShape="RoundRectangle 24"
                        Stroke="Transparent"
                        StrokeThickness="0"
                        BackgroundColor="#33FFFFFF"
                        WidthRequest="48" HeightRequest="48"
                        VerticalOptions="Center"
                        HorizontalOptions="End">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleCameraCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="🔄"
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- Mode Selector Row -->
            <HorizontalStackLayout Grid.Row="1"
                                   HorizontalOptions="Center"
                                   Spacing="24">
                <Label Text="Photo"
                       FontSize="14"
                       TextColor="{Binding SelectedMode, Converter={StaticResource ModeToTextColorConverter}, ConverterParameter=Photo}"
                       FontAttributes="{Binding SelectedMode, Converter={StaticResource ModeToFontConverter}, ConverterParameter=Photo}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetPhotoModeCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="Video"
                       FontSize="14"
                       TextColor="{Binding SelectedMode, Converter={StaticResource ModeToTextColorConverter}, ConverterParameter=Video}"
                       FontAttributes="{Binding SelectedMode, Converter={StaticResource ModeToFontConverter}, ConverterParameter=Video}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetVideoModeCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </Grid>

        <!-- Settings Overlay (spans full screen above both rows) -->
        <views:SensorValueSettingsView
            x:Name="SettingsOverlay"
            Grid.RowSpan="2"
            IsVisible="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IsSettingsVisible}"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            InputTransparent="False" />
    </Grid>
</ContentPage>
