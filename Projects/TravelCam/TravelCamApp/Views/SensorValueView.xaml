<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TravelCamApp.Models"
             x:Class="TravelCamApp.Views.SensorValueView">

    <!--
        Sensor overlay: compact dark pill in the bottom-right of the camera preview.
        Each visible sensor shows as two lines — label (gray, small) above value (white, bold).
        FontSize is driven by SensorValueViewModel.LabelFontSize / ValueFontSize (slider-controlled).
        Tap the overlay to open sensor settings.
    -->
    <Border BackgroundColor="#99000000"
            StrokeShape="RoundRectangle 10"
            Stroke="Transparent"
            Padding="10,8"
            MaximumWidthRequest="160">
        <VerticalStackLayout Spacing="4">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
            </VerticalStackLayout.GestureRecognizers>

            <CollectionView ItemsSource="{Binding SensorItems}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SensorItem">
                        <!-- Each sensor entry: label line + value line -->
                        <VerticalStackLayout IsVisible="{Binding IsVisible}"
                                            Spacing="0"
                                            Margin="0,0,0,4">
                            <!-- Sensor label (muted gray, uppercase) — size from SensorValueViewModel.LabelFontSize -->
                            <Label Text="{Binding Name}"
                                   FontSize="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SensorValueViewModel.LabelFontSize}"
                                   CharacterSpacing="0.6"
                                   TextColor="#9E9E9E"
                                   LineBreakMode="NoWrap"
                                   TextTransform="Uppercase" />
                            <!-- Sensor value (white, bold) — size from SensorValueViewModel.ValueFontSize -->
                            <Label Text="{Binding Value}"
                                   FontSize="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SensorValueViewModel.ValueFontSize}"
                                   FontAttributes="Bold"
                                   TextColor="#FFFFFF"
                                   LineBreakMode="NoWrap" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </Border>

</ContentView>
