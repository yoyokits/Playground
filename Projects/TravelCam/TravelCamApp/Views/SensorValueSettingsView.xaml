<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TravelCamApp.Models"
             x:Class="TravelCamApp.Views.SensorValueSettingsView"
             x:Name="SettingsRoot" >

    <ContentView.Content>
        <!-- Semi-transparent backdrop -->
        <AbsoluteLayout BackgroundColor="#B2000000">
            <!-- Settings Panel -->
            <ScrollView AbsoluteLayout.LayoutBounds="0.5,0.5,360,600"
                        AbsoluteLayout.LayoutFlags="PositionProportional"
                        BackgroundColor="{StaticResource MD3Surface}">
                <VerticalStackLayout Padding="20" Spacing="16">
                    <!-- Header -->
                    <Label Text="Sensor Settings"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource MD3OnSurface}" />

                    <!-- Visible Sensors -->
                    <Border BackgroundColor="{StaticResource MD3Surface}"
                            Stroke="{StaticResource MD3OutlineVariant}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Visible Sensors"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource MD3OnSurface}" />
                            <CollectionView x:Name="VisibleSensorsList"
                                            ItemsSource="{Binding VisibleSensorItems}"
                                            SelectionMode="Single"
                                            HeightRequest="120"
                                            SelectedItem="{Binding SelectedVisibleItem, Mode=TwoWay}"
                                            CanReorderItems="True"
                                            ReorderCompleted="OnVisibleListReorderCompleted">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:SensorItem">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                                            <Label Grid.Column="0" Text="☰" FontSize="14"
                                                   VerticalOptions="Center" Margin="8,0"
                                                   TextColor="{StaticResource MD3OnSurfaceVariant}" />
                                            <Border Grid.Column="1" Padding="10,8"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{StaticResource MD3PrimaryContainer}">
                                                <Label Text="{Binding Name}" FontSize="13"
                                                       TextColor="{StaticResource MD3OnPrimaryContainer}"
                                                       VerticalOptions="Center" />
                                            </Border>
                                            <Border Grid.Column="2"
                                                    BackgroundColor="{StaticResource MD3Error}"
                                                    StrokeThickness="0" Padding="10,8"
                                                    VerticalOptions="Fill">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={x:Reference SettingsRoot}, Path=BindingContext.MoveToAvailableCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="✕" FontSize="12" TextColor="White"
                                                       VerticalOptions="Center" HorizontalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Text="＋ Add"
                                Clicked="OnAddButtonClicked"
                                BackgroundColor="{StaticResource MD3Primary}"
                                TextColor="{StaticResource MD3OnPrimary}"
                                FontSize="12" HeightRequest="32" CornerRadius="16" />
                        <Button Grid.Column="1" Text="− Remove"
                                Clicked="OnRemoveButtonClicked"
                                BackgroundColor="{StaticResource MD3SecondaryContainer}"
                                TextColor="{StaticResource MD3OnSurface}"
                                FontSize="12" HeightRequest="32" CornerRadius="16" />
                    </Grid>

                    <!-- Available Sensors -->
                    <Border BackgroundColor="{StaticResource MD3Surface}"
                            Stroke="{StaticResource MD3OutlineVariant}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Available Sensors"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource MD3OnSurface}" />
                            <CollectionView x:Name="AvailableSensorsList"
                                            ItemsSource="{Binding AvailableSensorItems}"
                                            SelectionMode="Single"
                                            HeightRequest="120"
                                            SelectedItem="{Binding SelectedAvailableItem, Mode=TwoWay}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:SensorItem">
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                            <Border Grid.Column="0" Padding="10,8"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{StaticResource MD3SurfaceVariant}">
                                                <Label Text="{Binding Name}" FontSize="13"
                                                       TextColor="{StaticResource MD3OnSurfaceVariant}"
                                                       VerticalOptions="Center" />
                                            </Border>
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{StaticResource MD3Success}"
                                                    StrokeThickness="0" Padding="10,8"
                                                    VerticalOptions="Fill">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={x:Reference SettingsRoot}, Path=BindingContext.MoveToVisibleCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="＋" FontSize="12" TextColor="White"
                                                       VerticalOptions="Center" HorizontalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Font Size -->
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                        <HorizontalStackLayout Grid.Row="0">
                            <Label Text="Font Size" FontSize="13"
                                   TextColor="{StaticResource MD3OnSurfaceVariant}" VerticalOptions="Center" />
                            <Label Text="{Binding Source={x:Reference FontSizeSlider}, Path=Value, StringFormat=' ({0:F0})'}"
                                   FontSize="13" TextColor="{StaticResource MD3Primary}"
                                   FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Slider Grid.Row="1" x:Name="FontSizeSlider"
                                Minimum="8" Maximum="24"
                                Value="{Binding FontSize}"
                                DragCompleted="OnFontSizeChanged"
                                MinimumTrackColor="{StaticResource MD3Primary}"
                                MaximumTrackColor="{StaticResource MD3OutlineVariant}"
                                ThumbColor="{StaticResource MD3Primary}" />
                    </Grid>

                    <!-- Close Button -->
                    <Button Text="Close"
                            Clicked="OnCloseClicked"
                            BackgroundColor="{StaticResource MD3Primary}"
                            TextColor="{StaticResource MD3OnPrimary}"
                            FontSize="14" FontAttributes="Bold"
                            HeightRequest="44" CornerRadius="22" />
                </VerticalStackLayout>
            </ScrollView>
        </AbsoluteLayout>
    </ContentView.Content>
</ContentView>
