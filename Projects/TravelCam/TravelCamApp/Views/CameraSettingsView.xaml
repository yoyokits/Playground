<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:TravelCamApp.ViewModels"
             xmlns:converters="clr-namespace:TravelCamApp.Converters"
             x:Class="TravelCamApp.Views.CameraSettingsView"
             x:DataType="vm:CameraSettingsViewModel"
             x:Name="CamSettingsRoot">

    <ContentView.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvBool" />
        <converters:AspectRatioToBackgroundConverter x:Key="AspectRatioToBgConverter" />
        <converters:AspectRatioToTextColorConverter  x:Key="AspectRatioToTextConverter" />
    </ContentView.Resources>

    <ContentView.Content>
        <!-- Dimmed backdrop — tap outside the panel to close -->
        <AbsoluteLayout BackgroundColor="#CC000000">
            <AbsoluteLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackdropTapped" />
            </AbsoluteLayout.GestureRecognizers>

            <!-- Settings Panel — dark card, centered -->
            <Border AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                    AbsoluteLayout.LayoutFlags="PositionProportional"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="#111111"
                    Stroke="Transparent"
                    WidthRequest="320">
            <ScrollView BackgroundColor="#111111">
                <VerticalStackLayout Padding="0" Spacing="0">

                    <!-- ── Header ── -->
                    <Grid Padding="20,20,16,16"
                          ColumnDefinitions="*,Auto"
                          BackgroundColor="#111111">
                        <Label Grid.Column="0"
                               Text="CAMERA"
                               FontSize="13" CharacterSpacing="1.2"
                               FontAttributes="Bold" TextColor="#8E8E93"
                               VerticalOptions="Center" />
                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 16"
                                BackgroundColor="#2C2C2E" Stroke="Transparent"
                                WidthRequest="32" HeightRequest="32"
                                HorizontalOptions="End" VerticalOptions="Center">
                            <Label Text="✕" FontSize="13" TextColor="#ABABAB"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCloseClicked" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" />

                    <!-- ── Overlay section ── -->
                    <VerticalStackLayout Padding="20,16,20,0" Spacing="0"
                                         BackgroundColor="#111111">

                        <Label Text="OVERLAYS"
                               FontSize="11" CharacterSpacing="1.0"
                               FontAttributes="Bold" TextColor="#8E8E93"
                               Margin="0,0,0,10" />

                        <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                BackgroundColor="#1C1C1E" Padding="0">
                            <VerticalStackLayout Spacing="0">

                                <!-- Rule of thirds toggle -->
                                <Grid ColumnDefinitions="*,Auto"
                                      Padding="16,14" HeightRequest="52">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2"
                                                          VerticalOptions="Center">
                                        <Label Text="Rule of Thirds" FontSize="14"
                                               TextColor="#FFFFFF" />
                                        <Label Text="Guide lines on camera view"
                                               FontSize="11" TextColor="#636366" />
                                    </VerticalStackLayout>
                                    <Switch Grid.Column="1"
                                            IsToggled="{Binding ShowRuleOfThirds}"
                                            OnColor="#30D158"
                                            ThumbColor="White"
                                            VerticalOptions="Center" />
                                </Grid>

                                <!-- Divider -->
                                <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E"
                                         Margin="16,0" />

                                <!-- Data overlay toggle -->
                                <Grid ColumnDefinitions="*,Auto"
                                      Padding="16,14" HeightRequest="52">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2"
                                                          VerticalOptions="Center">
                                        <Label Text="Data Overlay" FontSize="14"
                                               TextColor="#FFFFFF" />
                                        <Label Text="Show location &amp; weather data"
                                               FontSize="11" TextColor="#636366" />
                                    </VerticalStackLayout>
                                    <Switch Grid.Column="1"
                                            IsToggled="{Binding ShowDataOverlay}"
                                            OnColor="#30D158"
                                            ThumbColor="White"
                                            VerticalOptions="Center" />
                                </Grid>

                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>

                    <!-- ── Grid line opacity ── -->
                    <VerticalStackLayout Padding="20,16,20,0" Spacing="8"
                                         BackgroundColor="#111111">
                        <HorizontalStackLayout Spacing="0">
                            <Label Text="GRID OPACITY"
                                   FontSize="11" CharacterSpacing="1.0"
                                   FontAttributes="Bold" TextColor="#8E8E93"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding GridLineOpacity, StringFormat='  {0:P0}'}"
                                   FontSize="11" TextColor="#FFFFFF" FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Slider Minimum="0.05" Maximum="0.50"
                                Value="{Binding GridLineOpacity}"
                                MinimumTrackColor="#FFFFFF"
                                MaximumTrackColor="#3C3C3E"
                                ThumbColor="#FFFFFF"
                                IsEnabled="{Binding ShowRuleOfThirds}" />
                    </VerticalStackLayout>

                    <!-- ── Future settings (placeholder) ── -->
                    <VerticalStackLayout Padding="20,16,20,24" Spacing="10"
                                         BackgroundColor="#111111">

                        <Label Text="CAPTURE"
                               FontSize="11" CharacterSpacing="1.0"
                               FontAttributes="Bold" TextColor="#8E8E93" />

                        <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                BackgroundColor="#1C1C1E" Padding="0">
                            <VerticalStackLayout Spacing="0">

                                <!-- Resolution selector -->
                                <Grid ColumnDefinitions="*,Auto"
                                      Padding="16,6,8,6" MinimumHeightRequest="52">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2"
                                                          VerticalOptions="Center">
                                        <Label Text="Resolution" FontSize="14"
                                               TextColor="#FFFFFF" />
                                        <Label Text="Photo capture resolution"
                                               FontSize="11" TextColor="#636366" />
                                    </VerticalStackLayout>
                                    <Picker Grid.Column="1"
                                            ItemsSource="{Binding AvailableResolutionLabels}"
                                            SelectedIndex="{Binding SelectedResolutionIndex}"
                                            TextColor="#FFFFFF"
                                            TitleColor="#ABABAB"
                                            BackgroundColor="Transparent"
                                            WidthRequest="160"
                                            VerticalOptions="Center" />
                                </Grid>

                                <!-- Divider -->
                                <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E"
                                         Margin="16,0" />

                                <!-- Aspect Ratio selector -->
                                <VerticalStackLayout Padding="16,14,16,14" Spacing="10">
                                    <Label Text="Aspect Ratio" FontSize="14"
                                           TextColor="#FFFFFF" />
                                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                                        <!-- Full -->
                                        <Border Grid.Column="0"
                                                StrokeShape="RoundRectangle 8" Stroke="Transparent"
                                                Padding="0,6"
                                                BackgroundColor="{Binding SelectedAspectRatio,
                                                    Converter={StaticResource AspectRatioToBgConverter},
                                                    ConverterParameter=FullScreen}">
                                            <Label Text="Full" FontSize="12" FontAttributes="Bold"
                                                   TextColor="{Binding SelectedAspectRatio,
                                                       Converter={StaticResource AspectRatioToTextConverter},
                                                       ConverterParameter=FullScreen}"
                                                   HorizontalOptions="Center" />
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SetAspectRatioCommand}"
                                                                      CommandParameter="FullScreen" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <!-- 4:3 -->
                                        <Border Grid.Column="1"
                                                StrokeShape="RoundRectangle 8" Stroke="Transparent"
                                                Padding="0,6"
                                                BackgroundColor="{Binding SelectedAspectRatio,
                                                    Converter={StaticResource AspectRatioToBgConverter},
                                                    ConverterParameter=FourThree}">
                                            <Label Text="4:3" FontSize="12" FontAttributes="Bold"
                                                   TextColor="{Binding SelectedAspectRatio,
                                                       Converter={StaticResource AspectRatioToTextConverter},
                                                       ConverterParameter=FourThree}"
                                                   HorizontalOptions="Center" />
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SetAspectRatioCommand}"
                                                                      CommandParameter="FourThree" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <!-- 16:9 -->
                                        <Border Grid.Column="2"
                                                StrokeShape="RoundRectangle 8" Stroke="Transparent"
                                                Padding="0,6"
                                                BackgroundColor="{Binding SelectedAspectRatio,
                                                    Converter={StaticResource AspectRatioToBgConverter},
                                                    ConverterParameter=SixteenNine}">
                                            <Label Text="16:9" FontSize="12" FontAttributes="Bold"
                                                   TextColor="{Binding SelectedAspectRatio,
                                                       Converter={StaticResource AspectRatioToTextConverter},
                                                       ConverterParameter=SixteenNine}"
                                                   HorizontalOptions="Center" />
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SetAspectRatioCommand}"
                                                                      CommandParameter="SixteenNine" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <!-- 1:1 -->
                                        <Border Grid.Column="3"
                                                StrokeShape="RoundRectangle 8" Stroke="Transparent"
                                                Padding="0,6"
                                                BackgroundColor="{Binding SelectedAspectRatio,
                                                    Converter={StaticResource AspectRatioToBgConverter},
                                                    ConverterParameter=OneOne}">
                                            <Label Text="1:1" FontSize="12" FontAttributes="Bold"
                                                   TextColor="{Binding SelectedAspectRatio,
                                                       Converter={StaticResource AspectRatioToTextConverter},
                                                       ConverterParameter=OneOne}"
                                                   HorizontalOptions="Center" />
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SetAspectRatioCommand}"
                                                                      CommandParameter="OneOne" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
            </Border>
        </AbsoluteLayout>
    </ContentView.Content>
</ContentView>
