<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:TravelCamApp.ViewModels"
             xmlns:models="clr-namespace:TravelCamApp.Models"
             x:Class="TravelCamApp.Views.OverlaySettingsPage"
             x:DataType="viewModels:OverlaySettingsViewModel"
             Title="Overlay Settings"
             BackgroundColor="#FFFBFE"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="MD3Primary">#6750A4</Color>
            <Color x:Key="MD3OnPrimary">#FFFFFF</Color>
            <Color x:Key="MD3PrimaryContainer">#EADDFF</Color>
            <Color x:Key="MD3OnPrimaryContainer">#21005D</Color>
            <Color x:Key="MD3Surface">#FFFBFE</Color>
            <Color x:Key="MD3SurfaceVariant">#E7E0EC</Color>
            <Color x:Key="MD3OnSurface">#1C1B1F</Color>
            <Color x:Key="MD3OnSurfaceVariant">#49454F</Color>
            <Color x:Key="MD3OutlineVariant">#CAC4D0</Color>
            <Color x:Key="MD3Error">#B3261E</Color>
            <Color x:Key="MD3Success">#386A20</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Header with Back Button -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" BackgroundColor="{StaticResource MD3Surface}" Padding="8,12">
            <Button Grid.Column="0"
                    Text="&lt; Back"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource MD3Primary}"
                    FontSize="14"
                    Padding="0"
                    HeightRequest="32" />
            <Label Grid.Column="1"
                   Text="Overlay Settings"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource MD3OnSurface}"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   Margin="0,0,60,0" />
        </Grid>

        <!-- Tab Buttons -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" BackgroundColor="{StaticResource MD3Surface}" Padding="4">
            <Button x:Name="VisibilityTab"
                    Grid.Column="0"
                    Text="Visibility"
                    Clicked="OnVisibilityTabClicked"
                    BackgroundColor="{StaticResource MD3Primary}"
                    TextColor="{StaticResource MD3OnPrimary}"
                    CornerRadius="8"
                    HeightRequest="40"
                    Margin="2" />
            <Button x:Name="AppearanceTab"
                    Grid.Column="1"
                    Text="Appearance"
                    Clicked="OnAppearanceTabClicked"
                    BackgroundColor="{StaticResource MD3SurfaceVariant}"
                    TextColor="{StaticResource MD3OnSurface}"
                    CornerRadius="8"
                    HeightRequest="40"
                    Margin="2" />
        </Grid>

        <!-- Visibility Content -->
        <ScrollView x:Name="VisibilityContent" Grid.Row="2" IsVisible="True">
            <VerticalStackLayout Spacing="12" Padding="12">
                <!-- Visible Items Section -->
                <Border BackgroundColor="{StaticResource MD3Surface}"
                        Stroke="{StaticResource MD3OutlineVariant}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="10">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="Visible Items"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource MD3OnSurface}" />
                            <Label Text="(drag to reorder)"
                                   FontSize="10"
                                   TextColor="{StaticResource MD3OnSurfaceVariant}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <CollectionView x:Name="VisibleItemsList"
                                        ItemsSource="{Binding VisibleOverlayItems}"
                                        SelectionMode="Single"
                                        HeightRequest="180"
                                        SelectedItem="{Binding SelectedVisibleItem, Mode=TwoWay}"
                                        SelectionChanged="OnVisibleListSelectionChanged"
                                        CanReorderItems="True"
                                        ReorderCompleted="OnVisibleListReorderCompleted">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:OverlayItem">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,1" HeightRequest="40">
                                        <Border Grid.Column="0"
                                                BackgroundColor="{StaticResource MD3SurfaceVariant}"
                                                StrokeShape="RoundRectangle 6,0,0,6"
                                                Stroke="Transparent"
                                                Padding="8,4">
                                            <Label Text="=" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource MD3OnSurfaceVariant}" VerticalOptions="Center" />
                                        </Border>
                                        <Border Grid.Column="1"
                                                BackgroundColor="{StaticResource MD3PrimaryContainer}"
                                                Stroke="Transparent"
                                                Padding="8,4">
                                            <Label Text="{Binding Name}" FontSize="13" TextColor="{StaticResource MD3OnPrimaryContainer}" VerticalOptions="Center" />
                                        </Border>
                                        <Border Grid.Column="2"
                                                BackgroundColor="{StaticResource MD3Error}"
                                                StrokeShape="RoundRectangle 0,6,6,0"
                                                Stroke="Transparent"
                                                Padding="8,4">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:OverlaySettingsViewModel}}, Path=MoveToAvailableCommand}" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="X" FontSize="14" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Available Items Section -->
                <Border BackgroundColor="{StaticResource MD3Surface}"
                        Stroke="{StaticResource MD3OutlineVariant}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="10">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Available Items"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource MD3OnSurface}" />

                        <CollectionView x:Name="AvailableItemsList"
                                        ItemsSource="{Binding AvailableOverlayItems}"
                                        SelectionMode="Single"
                                        HeightRequest="180"
                                        SelectedItem="{Binding SelectedAvailableItem, Mode=TwoWay}"
                                        SelectionChanged="OnAvailableListSelectionChanged">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:OverlayItem">
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,1" HeightRequest="40">
                                        <Border Grid.Column="0"
                                                BackgroundColor="{StaticResource MD3SurfaceVariant}"
                                                StrokeShape="RoundRectangle 6,0,0,6"
                                                Stroke="Transparent"
                                                Padding="8,4">
                                            <Label Text="{Binding Name}" FontSize="13" TextColor="{StaticResource MD3OnSurfaceVariant}" VerticalOptions="Center" />
                                        </Border>
                                        <Border Grid.Column="1"
                                                BackgroundColor="{StaticResource MD3Success}"
                                                StrokeShape="RoundRectangle 0,6,6,0"
                                                Stroke="Transparent"
                                                Padding="8,4">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:OverlaySettingsViewModel}}, Path=MoveToVisibleCommand}" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="+" FontSize="16" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Appearance Content -->
        <ScrollView x:Name="AppearanceContent" Grid.Row="2" IsVisible="False">
            <VerticalStackLayout Spacing="12" Padding="12">
                <Border BackgroundColor="{StaticResource MD3Surface}"
                        Stroke="{StaticResource MD3OutlineVariant}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="12">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Appearance Settings"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource MD3OnSurface}" />

                        <!-- Font Size -->
                        <VerticalStackLayout Spacing="8">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="Font Size:"
                                       FontSize="14"
                                       TextColor="{StaticResource MD3OnSurface}"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding Source={x:Reference FontSizeSlider}, Path=Value, StringFormat='{0:F0}'}"
                                       FontSize="14"
                                       TextColor="{StaticResource MD3Primary}"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Slider x:Name="FontSizeSlider"
                                    Minimum="8"
                                    Maximum="24"
                                    Value="{Binding FontSize}"
                                    DragCompleted="OnFontSizeChanged"
                                    MinimumTrackColor="{StaticResource MD3Primary}"
                                    MaximumTrackColor="{StaticResource MD3OutlineVariant}"
                                    ThumbColor="{StaticResource MD3Primary}" />
                        </VerticalStackLayout>

                        <!-- Map Overlay Toggle -->
                        <Grid ColumnDefinitions="*,Auto" Padding="8" BackgroundColor="{StaticResource MD3SurfaceVariant}">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Map Overlay" FontSize="14" TextColor="{StaticResource MD3OnSurface}" />
                                <Label Text="Show map on overlay" FontSize="12" TextColor="{StaticResource MD3OnSurfaceVariant}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding IsMapOverlayVisible}"
                                    Toggled="OnMapOverlayToggled"
                                    OnColor="{StaticResource MD3Primary}"
                                    VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
