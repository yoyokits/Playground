<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TravelCamApp.Models"
             xmlns:vm="clr-namespace:TravelCamApp.ViewModels"
             x:Class="TravelCamApp.Views.OverlaySettingsView"
             x:DataType="vm:OverlaySettingsViewModel"
             x:Name="SettingsRoot">

    <ContentView.Content>
        <!-- Dimmed backdrop -->
        <AbsoluteLayout BackgroundColor="#CC000000">

            <!-- Settings Panel — dark card centered -->
            <ScrollView AbsoluteLayout.LayoutBounds="0.5,0.5,340,0.88"
                        AbsoluteLayout.LayoutFlags="PositionProportional,HeightProportional"
                        BackgroundColor="#111111">
                <VerticalStackLayout Padding="0" Spacing="0">

                    <!-- ── Header ── -->
                    <Grid Padding="20,20,16,16"
                          ColumnDefinitions="*,Auto"
                          BackgroundColor="#111111">
                        <Label Grid.Column="0"
                               Text="SENSOR OVERLAY"
                               FontSize="13"
                               CharacterSpacing="1.2"
                               FontAttributes="Bold"
                               TextColor="#8E8E93"
                               VerticalOptions="Center" />
                        <!-- Close X button -->
                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 16"
                                BackgroundColor="#2C2C2E" Stroke="Transparent"
                                WidthRequest="32" HeightRequest="32"
                                HorizontalOptions="End" VerticalOptions="Center">
                            <Label Text="✕" FontSize="13" TextColor="#ABABAB"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCloseClicked" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="0.5" BackgroundColor="#2C2C2E" Margin="0" />

                    <!-- ── Visible Sensors section ── -->
                    <VerticalStackLayout Padding="20,16,20,0" Spacing="10"
                                         BackgroundColor="#111111">

                        <Label Text="VISIBLE"
                               FontSize="11" CharacterSpacing="1.0"
                               FontAttributes="Bold" TextColor="#8E8E93" />

                        <!-- Visible items list -->
                        <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                BackgroundColor="#1C1C1E" Padding="0"
                                MinimumHeightRequest="48">
                            <CollectionView x:Name="VisibleSensorsList"
                                            ItemsSource="{Binding VisibleOverlayItems}"
                                            SelectionMode="Single"
                                            HeightRequest="148"
                                            SelectedItem="{Binding SelectedVisibleItem, Mode=TwoWay}"
                                            CanReorderItems="True"
                                            ReorderCompleted="OnVisibleListReorderCompleted">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:OverlayItem">
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              Padding="14,0" HeightRequest="46">
                                            <!-- Drag handle -->
                                            <Label Grid.Column="0"
                                                   Text="≡" FontSize="16"
                                                   TextColor="#3C3C3E"
                                                   VerticalOptions="Center"
                                                   Margin="0,0,10,0" />
                                            <!-- Sensor name -->
                                            <Label Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="14" TextColor="#FFFFFF"
                                                   VerticalOptions="Center" />
                                            <!-- Remove (−) -->
                                            <Border Grid.Column="2"
                                                    StrokeShape="RoundRectangle 14"
                                                    BackgroundColor="#3A1A1A" Stroke="Transparent"
                                                    WidthRequest="28" HeightRequest="28"
                                                    VerticalOptions="Center">
                                                <Label Text="−" FontSize="16" TextColor="#FF453A"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       Margin="0,0,0,2" />
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnItemRemoveClicked" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>

                    </VerticalStackLayout>

                    <!-- ── Available Sensors section ── -->
                    <VerticalStackLayout Padding="20,16,20,0" Spacing="10"
                                         BackgroundColor="#111111">

                        <Label Text="AVAILABLE"
                               FontSize="11" CharacterSpacing="1.0"
                               FontAttributes="Bold" TextColor="#8E8E93" />

                        <!-- Available items list -->
                        <Border StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                BackgroundColor="#1C1C1E" Padding="0"
                                MinimumHeightRequest="48">
                            <CollectionView x:Name="AvailableSensorsList"
                                            ItemsSource="{Binding AvailableOverlayItems}"
                                            SelectionMode="Single"
                                            HeightRequest="148"
                                            SelectedItem="{Binding SelectedAvailableItem, Mode=TwoWay}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:OverlayItem">
                                        <Grid ColumnDefinitions="*,Auto"
                                              Padding="14,0" HeightRequest="46">
                                            <!-- Sensor name -->
                                            <Label Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontSize="14" TextColor="#ABABAB"
                                                   VerticalOptions="Center" />
                                            <!-- Add (+) -->
                                            <Border Grid.Column="1"
                                                    StrokeShape="RoundRectangle 14"
                                                    BackgroundColor="#1A3A1A" Stroke="Transparent"
                                                    WidthRequest="28" HeightRequest="28"
                                                    VerticalOptions="Center">
                                                <Label Text="+" FontSize="16" TextColor="#30D158"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       Margin="0,0,0,1" />
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnItemAddClicked" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>

                    </VerticalStackLayout>

                    <!-- ── Font Size slider ── -->
                    <VerticalStackLayout Padding="20,16,20,0" Spacing="8"
                                         BackgroundColor="#111111">
                        <HorizontalStackLayout Spacing="0">
                            <Label Text="LABEL SIZE"
                                   FontSize="11" CharacterSpacing="1.0"
                                   FontAttributes="Bold" TextColor="#8E8E93"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding Source={x:Reference FontSizeSlider}, Path=Value, StringFormat='  {0:F0} pt'}"
                                   FontSize="11" TextColor="#FFFFFF"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Slider x:Name="FontSizeSlider"
                                Minimum="8" Maximum="24"
                                Value="{Binding FontSize}"
                                MinimumTrackColor="#FFFFFF"
                                MaximumTrackColor="#3C3C3E"
                                ThumbColor="#FFFFFF" />
                    </VerticalStackLayout>

                    <!-- ── Tip text ── -->
                    <Label Margin="20,12,20,24"
                           Text="Drag items in Visible list to reorder. Tap + or − to move sensors."
                           FontSize="11" TextColor="#636366"
                           LineBreakMode="WordWrap" />

                </VerticalStackLayout>

            </ScrollView>

        </AbsoluteLayout>
    </ContentView.Content>

</ContentView>